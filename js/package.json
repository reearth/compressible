{
  "name": "@reearth/compressible",
  "version": "0.1.0",
  "description": "Tells you whether a file extension is worth gzip-compressing. Curated from jshttp/mime-db.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reearth/compressible.git",
    "directory": "js"
  },
  "homepage": "https://github.com/reearth/compressible#readme",
  "bugs": "https://github.com/reearth/compressible/issues",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "gzip",
    "compressible",
    "mime",
    "content-encoding",
    "cdn"
  ],
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
